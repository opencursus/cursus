# Build artifacts
/dist
/dist-ssr
*.local
/src-tauri/target
/src-tauri/gen
/src-tauri/WixTools

# Node
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Logs (defensive — IMAP/SMTP traces can leak credentials)
*.log
stdout.txt
stderr.txt

# Internal documentation — kept out of the public repo.
/DOCUMENTATION/

# Portable runtime data — created next to the executable on first launch.
# Contains the user's accounts, drafts, search index and sent log. Never commit.
cursus-files/
**/cursus-files/

# Local databases — defensive (anything *.db / *.sqlite outside cursus-files/).
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.~lock.*

# Backups
*.bak
*.orig

# Cache
.cache/
.parcel-cache/
.eslintcache
.turbo/

# Cargo backup files
**/*.rs.bk
